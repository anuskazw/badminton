{
  "name": "badminton",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://anuskazw.github.io/badminton",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "exceljs": "^4.4.0",
    "json-server": "^1.0.0-beta.3",
    "jspdf": "^4.2.1",
